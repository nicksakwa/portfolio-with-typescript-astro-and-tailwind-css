---
import { Image } from "astro:assets";
import type { HeaderProps } from "@types";

type Props = HeaderProps;

const { siteLogo, navLinks } = Astro.props;
---

<!-- Top Navigation Bar for Mobile/Tablet with Dropdown -->
<header class="fixed left-0 right-0 top-0 z-50 bg-black/95 backdrop-blur-sm border-b border-neutral/20 lg:hidden">
  <div class="flex items-center justify-between px-6 py-4">
    <a href="/" aria-label="Home link" class="flex items-center gap-3">
      <Image
        class="rounded-full"
        src={siteLogo}
        width="40"
        height="40"
        alt="website logo"
      />
      <span class="font-serif text-lg font-bold text-white">Portfolio</span>
    </a>
    
    <!-- Hamburger Menu Button -->
    <button id="menu-toggle" class="text-white hover:text-primary transition-colors" aria-label="Toggle menu">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>
  
  <!-- Dropdown Menu -->
  <nav id="mobile-menu" class="hidden bg-black/98 border-t border-neutral/20">
    <ul class="py-4">
      {navLinks.map((link) => (
        <li>
          <a
            class="mobile-nav-item block px-6 py-3 text-base font-medium text-neutral hover:bg-[#1d4ed8] hover:text-white transition-colors"
            href={link.href}
          >
            {link.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<!-- Desktop Sidebar -->
<aside class="hidden lg:flex fixed left-0 top-0 h-screen bg-[#2563eb] border-r border-white/10 z-50 w-64 flex-col">
  <div class="flex flex-col h-full">
    <!-- Sidebar Header -->
    <div class="flex items-center gap-3 p-6 border-b border-white/10">
      <a href="/" aria-label="Home link" class="flex items-center gap-3">
        <Image
          class="rounded-full ring-2 ring-white/20"
          src={siteLogo}
          width="50"
          height="50"
          alt="website logo"
        />
        <span class="font-serif text-xl font-bold text-white">Portfolio</span>
      </a>
    </div>

    <!-- Navigation Links -->
    <nav class="flex-1 p-6">
      <ul class="space-y-2">
        {navLinks.map((link) => {
          const icons = {
            'Experience': '<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />',
            'Projects': '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />',
            'Publications': '<path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" />',
            'YouTube': '<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z" />',
            'About': '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />'
          };
          const iconPath = icons[link.text as keyof typeof icons] || icons['About'];
          return (
            <li>
              <a
                class="nav-item group flex items-center gap-4 p-4 rounded-xl transition-all duration-300 hover:bg-[#1d4ed8] text-white"
                href={link.href}
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6" set:html={iconPath} />
                <span class="text-base font-medium">{link.text}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <!-- Sidebar Footer -->
    <div class="p-6 border-t border-white/10">
      <p class="text-sm text-white/80 text-center">© IT & Digital Developer 2026</p>
    </div>
  </div>
</aside>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileNavItems = document.querySelectorAll('.mobile-nav-item');
  const navItems = document.querySelectorAll('.nav-item');

  // Toggle mobile menu
  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Close mobile menu when clicking a link
  mobileNavItems.forEach((item) => {
    item?.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });

  // Update active nav item based on scroll
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            const href = item.getAttribute('href');
            if (href === `/#${entry.target.id}`) {
              item.classList.add('bg-[#1d4ed8]');
            } else {
              item.classList.remove('bg-[#1d4ed8]');
            }
          });
          
          mobileNavItems.forEach((item) => {
            const href = item.getAttribute('href');
            if (href === `/#${entry.target.id}`) {
              item.classList.add('bg-[#1d4ed8]');
            } else {
              item.classList.remove('bg-[#1d4ed8]');
            }
          });
        }
      });
    },
    { threshold: 0.3 },
  );

  document.querySelectorAll('section').forEach((section) => {
    observer.observe(section);
  });
</script>
