---
import type { SiteConfig } from "@types";

type Props = Pick<SiteConfig, "author" | "socialLinks">;

const { author, socialLinks } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer
  class="w-full border-t border-neutral/20 px-8 lg:px-12 pt-8 pb-10 text-center text-white mt-12"
>
  <ul class="mb-6 flex flex-wrap justify-center gap-x-6 text-base md:text-lg">
    {
      socialLinks.map(({ text, href }) => (
        <li>
          <a
            href={href}
            target="_blank"
            class="inline-block px-4 py-3 after:relative after:bottom-[-4px] after:content-[url(/external.svg)] hover:bg-[#1d4ed8] hover:text-white rounded-lg transition-colors"
          >
            {text}
          </a>
        </li>
      ))
    }
  </ul>
  <p class="text-sm md:text-base">
    {author} © {currentYear}. <span class="text-neutral"
      >Designed & Developed by</span
    > Nick Sakwa
  </p>
</footer>
