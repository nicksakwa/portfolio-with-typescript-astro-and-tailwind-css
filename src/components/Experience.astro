---
import Section from "./Section.astro";
import type { ExperienceProps } from "@types";

interface Props {
  experience: ExperienceProps[];
}

const { experience } = Astro.props;
---

<Section text="Work Experience" href="experience">
  <div class="grid gap-8 md:grid-cols-2">
    {
      experience.map(({ company, position, startDate, endDate, summary }) => (
        <div class="rounded-2xl border border-neutral/20 bg-[#1c232d]/50 p-8 hover:border-primary/40 transition-all">
          <h3 class="mb-2 font-serif text-2xl md:text-3xl font-semibold text-white">
            {company}
          </h3>
          <div class="flex flex-col items-start pb-6 border-b border-neutral/20 mb-6">
            <h4 class="mb-1 font-serif text-xl md:text-2xl font-medium text-primary">
              {position}
            </h4>
            <span class="text-sm md:text-base text-white/70">
              {startDate} — {endDate}
            </span>
          </div>
          {Array.isArray(summary) ? (
            <ul class="list-none space-y-3">
              {summary.map((log) => (
                <li class="relative pl-8 text-base md:text-lg text-neutral leading-relaxed before:absolute before:top-1 before:left-0 before:content-[url(/check.svg)]">
                  {log}
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-base md:text-lg text-neutral leading-relaxed">{summary}</p>
          )}
        </div>
      ))
    }
  </div>
</Section>
