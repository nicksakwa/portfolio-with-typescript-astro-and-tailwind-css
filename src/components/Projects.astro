---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { ProjectProps } from "@types";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;

// Images with mobile (.png) and desktop (.jpg) alternatives
const hasResponsiveImage = (imgPath: string) => {
  const responsiveImages = ['limbopay.png', 'yassako.png', 'lyxa.png', 'chatpay.png', 'azawadi.png'];
  return responsiveImages.some(img => imgPath.includes(img));
};

const getDesktopImage = (imgPath: string) => {
  return imgPath.replace('.png', '.jpg');
};
---

<Section text="Featured Projects" href="projects">
  {
    projects.map(({ name, summary, image, linkPreview, linkSource }, index) => {
      const top = 98 + index * 50;
      const useResponsive = hasResponsiveImage(image);
      const desktopImage = useResponsive ? getDesktopImage(image) : image;
      
      return (
        <div
          style={`top: ${top}px;`}
          class="sticky mb-16 sm:mb-20 rounded-2xl border border-neutral/20 bg-black"
        >
          <div class="bg-difu relative z-[1] grid w-full grid-rows-[auto_300px] rounded-2xl bg-[#1c232d]/85 before:absolute before:inset-0 before:z-[-1] before:rounded-2xl before:bg-[url(/raja.png)] before:bg-[length:128px] before:bg-repeat before:opacity-[5%] before:content-[''] sm:grid-cols-[40%_60%] sm:grid-rows-1 sm:min-h-[500px] md:min-h-[550px] lg:min-h-[580px]">
            <div class="px-6 pt-8 pb-8 sm:px-7 sm:pt-10 sm:pb-12 md:px-9 md:pt-12 md:pb-14 flex flex-col order-2 sm:order-1">
              <div class="flex-1 min-h-0">
                <h3 class="mb-3 sm:mb-4 md:mb-5 font-serif text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-medium text-primary leading-tight">
                  {name}
                </h3>
                <p class="text-base sm:text-lg md:text-xl lg:text-2xl text-neutral leading-relaxed">{summary}</p>
              </div>
              <div class="flex flex-wrap gap-5 sm:gap-6 pt-8 sm:pt-10 mt-auto text-white text-base sm:text-lg md:text-xl flex-shrink-0">
                <a
                  href={linkSource}
                  target="_blank"
                  class="inline-flex items-center gap-2 after:content-[url(/external.svg)] hover:underline"
                >
                  Source
                </a>
                <a
                  href={linkPreview}
                  target="_blank"
                  class="inline-flex items-center gap-2 after:content-[url(/external.svg)] hover:underline"
                >
                  Preview
                </a>
              </div>
            </div>
            <div class="flex items-center justify-center bg-gradient-to-br from-slate-800/30 to-slate-900/30 rounded-t-2xl sm:rounded-l-none sm:rounded-r-2xl p-6 sm:p-8 md:p-10 order-1 sm:order-2">
              {useResponsive ? (
                <>
                  {/* Mobile: PNG version */}
                  <Image
                    class="block sm:hidden w-full h-full rounded-lg object-contain drop-shadow-2xl"
                    src={image}
                    alt={name}
                    width="736"
                    height="483"
                  />
                  {/* Tablet: JPG version */}
                  <Image
                    class="hidden sm:block lg:hidden w-full h-full rounded-lg object-contain drop-shadow-2xl"
                    src={desktopImage}
                    alt={name}
                    width="736"
                    height="483"
                  />
                  {/* Desktop: PNG version */}
                  <Image
                    class="hidden lg:block w-full h-full rounded-lg object-contain drop-shadow-2xl"
                    src={image}
                    alt={name}
                    width="736"
                    height="483"
                  />
                </>
              ) : (
                <Image
                  class="w-full h-full rounded-lg object-contain drop-shadow-2xl"
                  src={image}
                  alt={name}
                  width="736"
                  height="483"
                />
              )}
            </div>
          </div>
        </div>
      );
    })
  }
</Section>
