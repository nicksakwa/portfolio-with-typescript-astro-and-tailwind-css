---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { ProjectProps } from "@types";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<Section text="Featured Projects" href="projects">
  {
    projects.map(({ name, summary, image, linkPreview, linkSource }, index) => {
      const top = 98 + index * 40;
      return (
        <div
          style={`top: ${top}px;`}
          class="sticky mb-12 rounded-2xl border border-neutral/20 bg-black"
        >
          <div class="bg-difu relative z-[1] grid w-full grid-rows-[auto_300px] rounded-2xl bg-[#1c232d]/85 before:absolute before:inset-0 before:z-[-1] before:rounded-2xl before:bg-[url(/raja.png)] before:bg-[length:128px] before:bg-repeat before:opacity-[5%] before:content-[''] sm:grid-cols-[45%_55%] sm:grid-rows-1 sm:h-[480px] md:h-[520px] lg:h-[540px]">
            <div class="px-6 pt-8 pb-6 sm:px-8 sm:pt-10 sm:pb-10 md:px-10 md:pt-12 md:pb-12 flex flex-col justify-between order-2 sm:order-1">
              <div>
                <h3 class="mb-3 sm:mb-4 md:mb-5 font-serif text-2xl sm:text-3xl md:text-4xl font-medium text-primary leading-tight">
                  {name}
                </h3>
                <p class="text-sm sm:text-base md:text-lg text-neutral leading-relaxed">{summary}</p>
              </div>
              <div class="flex gap-5 pt-6 sm:pt-8 text-white text-sm sm:text-base">
                <a
                  href={linkSource}
                  target="_blank"
                  class="after:relative after:bottom-[-5px] after:content-[url(/external.svg)] hover:underline"
                >
                  Source
                </a>
                <a
                  href={linkPreview}
                  target="_blank"
                  class="after:relative after:bottom-[-5px] after:content-[url(/external.svg)] hover:underline"
                >
                  Preview
                </a>
              </div>
            </div>
            <div class="flex items-center justify-center bg-gradient-to-br from-slate-800/30 to-slate-900/30 rounded-t-2xl sm:rounded-l-none sm:rounded-r-2xl p-6 sm:p-6 md:p-8 order-1 sm:order-2">
              <Image
                class="w-full h-full rounded-lg object-contain drop-shadow-2xl sm:object-cover sm:object-center"
                src={image}
                alt={name}
                width="736"
                height="483"
              />
            </div>
          </div>
        </div>
      );
    })
  }
</Section>
