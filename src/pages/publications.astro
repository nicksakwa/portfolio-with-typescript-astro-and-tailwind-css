---
import { SITE_CONTENT } from "@config";
import Layout from "@layouts/Layout.astro";
import PublicationsList from "@components/Publications.astro";

import "../styles/global.css";
---

<Layout>
  <div class="min-h-screen pt-20 lg:pt-8">
    <!-- Page Header -->
    <div class="text-center mb-16 px-8">
      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6">
        My Publications
      </h1>
      <p class="text-lg md:text-xl lg:text-2xl text-neutral max-w-3xl mx-auto leading-relaxed">
        Thoughts, insights, and technical articles about software development, programming languages, and emerging technologies.
      </p>
    </div>

    <PublicationsList publications={SITE_CONTENT.publications} />
  </div>
</Layout>
